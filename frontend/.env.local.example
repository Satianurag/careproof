# CareProof Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Contract address from deployment.json (after deploying the contract)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Optional: Override the default localnet indexer URL (default: http://127.0.0.1:8088/api/v3/graphql)
# INDEXER_URL=http://127.0.0.1:8088/api/v3/graphql
