# =============================================================================
# CareProof Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your target network.

# --- Network Selection ---
# Options: undeployed | preview | preprod | mainnet
MIDNIGHT_NETWORK=preview

# --- Wallet ---
# 64-character hex seed for server-side wallet operations (deploy scripts)
WALLET_SEED=

# --- Override Endpoints (optional — defaults per network are built-in) ---
# INDEXER_URL=https://indexer.preview.midnight.network/api/v3/graphql
# INDEXER_WS_URL=wss://indexer.preview.midnight.network/api/v3/graphql/ws
# NODE_URL=https://rpc.preview.midnight.network
# PROOF_SERVER_URL=https://lace-proof-pub.preview.midnight.network

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_NETWORK_NAME=Preview Testnet
NEXT_PUBLIC_INDEXER_URL=https://indexer.preview.midnight.network/api/v3/graphql
