# =============================================================================
# CareProof Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your target network.

# --- Network Selection ---
# Options: preview | preprod
MIDNIGHT_NETWORK=preprod

# --- Wallet ---
# 64-character hex seed for server-side wallet operations (deploy scripts)
WALLET_SEED=

# --- Private State Encryption ---
# At least 16 characters. Used to encrypt local contract private state.
PRIVATE_STATE_PASSWORD=

# --- Override Endpoints (optional — defaults per network are built-in) ---
# INDEXER_URL=https://indexer.preprod.midnight.network/api/v3/graphql
# INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v3/graphql/ws
# NODE_URL=https://rpc.preprod.midnight.network
# PROOF_SERVER_URL=https://lace-proof-pub.preprod.midnight.network

# --- Frontend (Next.js public vars) ---
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_NETWORK_NAME=Preprod
NEXT_PUBLIC_INDEXER_URL=https://indexer.preprod.midnight.network/api/v3/graphql
NEXT_PUBLIC_MIDNIGHT_NETWORK=preprod
